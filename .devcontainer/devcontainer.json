{
    "name": "Arch PHP + MariaDB",
    "dockerComposeFile": "docker-compose.yaml",
    "service": "app",

    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "ms-azuretools.vscode-docker"
            ]
        }
    },

    "forwardPorts": [8000, 3306]
}
